# ─────────────────────────────────────────────────────────────────────────────
# SECRET values. Copy this file to ".env" and fill in real values.
# ".env" is gitignored and must NEVER be committed.
# Loaded by the Tiltfile into a Secret named "app-secrets".
# ─────────────────────────────────────────────────────────────────────────────

# MinIO root credentials
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# S3 credentials used by mlflow + workers to reach MinIO.
# For MinIO these are typically the same as the root user/password above.
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
