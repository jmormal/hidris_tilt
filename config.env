# ─────────────────────────────────────────────────────────────────────────────
# Non-secret shared config. SAFE TO COMMIT.
# Loaded by the Tiltfile into a ConfigMap named "app-config" and pulled into
# pods via envFrom. One source of truth for hosts, URLs, and queue names.
#
# Rule: only values that are the SAME for every service belong here.
# Per-service values (e.g. which queue a worker drains) stay inline in the
# pod spec, NOT here.
# ─────────────────────────────────────────────────────────────────────────────

# Redis
REDIS_URL=redis://redis:6379

# Queue names (the api pushes to these; workers read one each)
QUEUE_GPU=jobs:gpu
QUEUE_CPU=jobs:cpu

# MLflow
MLFLOW_TRACKING_URI=http://mlflow:80

# MinIO / S3 endpoint (the URL is not secret; the credentials are — see .env)
MLFLOW_S3_ENDPOINT_URL=http://minio:9000
